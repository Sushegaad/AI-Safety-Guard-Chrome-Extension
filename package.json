{
  "name": "ai-safety-guard",
  "version": "1.0.0",
  "description": "A free Chrome extension that warns you before you send private information to an AI tool. Calm, plain-English, helpful — never punitive. Scanning happens on your device.",
  "private": true,
  "type": "module",
  "scripts": {
    "gen:tokens": "node scripts/gen-tokens.mjs",
    "prebuild": "node scripts/gen-tokens.mjs",
    "build": "npm run lint && webpack --mode production",
    "watch": "webpack --watch --mode development",
    "test": "node src/content/detector.test.mjs && node src/content/ui.test.mjs && node src/background/phase4.test.mjs && node src/content/files/files.test.mjs",
    "lint": "eslint src && npm run lint:css",
    "lint:css": "stylelint \"src/**/*.css\"",
    "bench": "node scripts/perf-bench.mjs",
    "audit:privacy": "node scripts/privacy-audit.mjs",
    "lint:ext": "web-ext lint --source-dir dist",
    "start:chrome": "web-ext run -t chromium --source-dir dist",
    "format": "prettier --write \"src/**/*.{js,css,html}\"",
    "gen:icons": "node scripts/gen-icons.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "copy-webpack-plugin": "^12.0.2",
    "eslint": "^9.39.4",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.3.3",
    "stylelint": "^17.14.0",
    "web-ext": "^8.2.0",
    "webpack": "^5.94.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "pdfjs-dist": "^6.1.200"
  }
}
